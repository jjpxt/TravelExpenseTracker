<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelExpenseTracker.Pages.TripDetailsPage"
             BackgroundColor="WhiteSmoke"
             xmlns:vm="clr-namespace:TravelExpenseTracker.ViewModels"
             xmlns:model="clr-namespace:TravelExpenseTracker.Models"
             x:DataType="vm:TripDetailsViewModel"
             Title="{Binding TripInfo.Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="plus.svg"/>
    </ContentPage.ToolbarItems>
    
    <ScrollView>
        <Grid RowDefinitions="150, Auto, *">
            <Image Source="{Binding TripInfo.Image}" HeightRequest="150" Grid.Row="0"/>

            <Border Grid.Row="1" StrokeShape="RoundRectangle 15" BackgroundColor="White" Padding="15" Margin="15,0">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="{Binding TripInfo.Title}" FontSize="20"/>
                        <Border BackgroundColor="Green"
                                StrokeShape="RoundRectangle 10"
                                Padding="4,2"
                                VerticalOptions="Center"
                                Margin="0,0,10,0"
                                Grid.Column="1">
                            <Label Text="{Binding TripInfo.Status}"
                                   TextColor="White"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="10">
                        <Image Source="map.svg" VerticalOptions="Center"/>
                        <Label Text="{Binding TripInfo.Location}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Image Source="calendar.svg" VerticalOptions="Center"/>
                        <Label Text="{Binding TripInfo.DisplayDateRange}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Image Source="dollar.svg" VerticalOptions="Center"/>
                        <Label Text="{Binding TotalExpenses , StringFormat='{0:C}'}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                <Border.Shadow>
                    <Shadow/>
                </Border.Shadow>
            </Border>

            <VerticalStackLayout Grid.Row="2" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Expenses" FontSize="20"/>
                    <Button Grid.Column="1" Text="Add Expense" Command="{Binding AddExpenseTempCommand}"/>
                </Grid>

                <CollectionView ItemsSource="{Binding Expenses}">
                    <CollectionView.EmptyView>
                        <ContentView>
                            <VerticalStackLayout HorizontalOptions="Center" 
                                                 VerticalOptions="Center" 
                                                 Padding="20">
                                <Label Text="No Expense added yet" 
                                       FontSize="18" 
                                       TextColor="DarkBlue"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </ContentView>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:ExpenseModel">
                            <Border BackgroundColor="White" 
                                    Stroke="LightGray" 
                                    StrokeThickness="1" 
                                    Padding="15" 
                                    Margin="0,5"
                                    StrokeShape="RoundRectangle 15">
                                <Grid RowDefinitions="Auto, Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" VerticalOptions="Center" 
                                               Text="{Binding Amount, StringFormat='{0:C}'}" FontSize="20"/>
                                        <HorizontalStackLayout Spacing="10" Grid.Column="1" Margin="10">
                                            <Image Source="calendar.svg" VerticalOptions="Center"/>
                                            <Label Text="{Binding SpentOn, StringFormat='{0:dd-MM-yy}'}" 
                                                   VerticalOptions="Center" FontSize="20"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                    <HorizontalStackLayout Spacing="10" Grid.Row="1">
                                        <Border BackgroundColor="{StaticResource Primary}" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 8" 
                                                Padding="10, 2">
                                            <Label Text="{Binding Category}" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="{Binding Title}" 
                                               FontSize="18" 
                                               FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
