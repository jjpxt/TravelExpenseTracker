<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelExpenseTracker.Pages.MainPage"
             BackgroundColor="WhiteSmoke"
             Title="Travel Expense Manager"
             xmlns:vm="clr-namespace:TravelExpenseTracker.ViewModels"
             xmlns:model="clr-namespace:TravelExpenseTracker.Models"
             x:DataType="vm:HomeViewModel"
             Shell.BackgroundColor="{StaticResource Primary}"
             Shell.TitleColor="WhiteSmoke">

    <Grid RowDefinitions="350, Auto,*" RowSpacing="10">
        <Image Grid.Row="0" Source="travel1.png" VerticalOptions="Start" HeightRequest="350" Aspect="Fill"/>
        
        <Grid Grid.Row="0" Margin="0, 300, 0,0" ColumnDefinitions="Auto, *, Auto" Padding="15,0">
            <Label Grid.Column="0" Text="Recent trips" FontSize="20"/>
            <Button Grid.Column="2" Text="Add a trip" VerticalOptions="Start" Command="{Binding AddTripTempCommand}"/>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Trips}" Margin="15,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" Padding="25" Margin="0, 50, 0, 0">
                    <Label Text="No trips yet" FontSize="30"/>
                    <Button Grid.Column="2" Text="Add a trip" VerticalOptions="Start" Margin="0, 15, 0, 0" Command="{Binding AddTripTempCommand}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Span="2" Orientation="Vertical" VerticalItemSpacing="15" HorizontalItemSpacing="15"/>
            </CollectionView.ItemsLayout>
            
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:TripModel">
                    <Border StrokeShape="RoundRectangle 15" BackgroundColor="White" StrokeThickness="0">
                        <VerticalStackLayout>
                            <Image Source="{Binding Image}" HeightRequest="100"/>
                            <Label Text="{Binding Title}" FontSize="18" Padding="10,0"/>
                            <Label Text="{Binding Location}" Padding="10,0"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
    </Grid>

</ContentPage>
